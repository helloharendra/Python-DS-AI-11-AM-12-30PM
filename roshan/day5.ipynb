   "metadata": {},
   "outputs": [],
   "source": [
    "# Binary Example\n",
    "a = 5  # → 0101\n",
    "b = 3   #→ 0011"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "051ea0e1",
   "metadata": {},
   "source": [
    "## And ##\n",
    "#### 1 only if both bits are 1 "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "b86c8415",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1\n"
     ]
    }
   ],
   "source": [
    "a = 5\n",
    "b = 3\n",
    "print(a & b)   # Output: 1"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a15fc2f5",
   "metadata": {},
   "source": [
    "## Or ##\n",
    "#### 1  if any of  both bits are 1 "
   ]
  }
